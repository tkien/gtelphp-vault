{
    "name": "gtelphp/vault",
    "description": "Production-ready PHP SDK for HashiCorp Vault and OpenBao, with first-class Laravel support.",
    "type": "library",
    "license": "MIT",
    "keywords": ["vault", "openbao", "hashicorp", "secrets", "kv", "transit", "laravel", "encryption"],
    "homepage": "https://github.com/gtelphp/vault",
    "authors": [
        {
            "name": "GtelPHP",
            "homepage": "https://github.com/gtelphp"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^2.0 || ^3.0",
        "psr/simple-cache": "^2.0 || ^3.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9",
        "orchestra/testbench": "^9.0 || ^10.0",
        "illuminate/database": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/console": "^11.0 || ^12.0",
        "mockery/mockery": "^1.6"
    },
    "suggest": {
        "ext-redis": "Required when using RedisTokenCache for AppRole token caching.",
        "illuminate/support": "Required to use the Laravel ServiceProvider, Facade and Eloquent casts."
    },
    "autoload": {
        "psr-4": {
            "GtelPhp\\Vault\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GtelPhp\\Vault\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GtelPhp\\Vault\\Laravel\\VaultServiceProvider"
            ],
            "aliases": {
                "Vault": "GtelPhp\\Vault\\Laravel\\Facades\\Vault"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "phpcs",
        "cs-fix": "phpcbf"
    }
}
